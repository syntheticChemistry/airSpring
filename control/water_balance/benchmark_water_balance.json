{
  "_source": "FAO Irrigation and Drainage Paper No. 56, Chapter 8 (Allen et al. 1998)",
  "_note": "Daily soil water balance for irrigation scheduling",

  "fao56_equations": {
    "water_balance": "Dr_i = Dr_{i-1} - (P_i - RO_i) - I_i - CR_i + ETc_adj_i + DP_i",
    "stress_coefficient": "Ks = (TAW - Dr) / (TAW - RAW)  when Dr > RAW, else 1.0",
    "total_available_water": "TAW = 1000 (θFC - θWP) Zr",
    "readily_available_water": "RAW = p × TAW",
    "etcrop_adjusted": "ETc_adj = Ks × Kc × ET0"
  },

  "soil_parameters": {
    "sandy_loam": {
      "theta_fc": 0.18,
      "theta_wp": 0.08,
      "description": "Michigan sandy loam (typical irrigated)"
    },
    "loam": {
      "theta_fc": 0.27,
      "theta_wp": 0.12,
      "description": "Generic loam"
    },
    "clay_loam": {
      "theta_fc": 0.36,
      "theta_wp": 0.20,
      "description": "Fine-textured soil"
    }
  },

  "crop_parameters": {
    "corn": {
      "kc_ini": 0.30,
      "kc_mid": 1.20,
      "kc_end": 0.60,
      "root_depth_m": 0.90,
      "depletion_fraction_p": 0.55,
      "season_days": 140
    },
    "blueberry": {
      "kc_ini": 0.30,
      "kc_mid": 1.05,
      "kc_end": 0.65,
      "root_depth_m": 0.45,
      "depletion_fraction_p": 0.50,
      "season_days": 180
    },
    "tomato": {
      "kc_ini": 0.60,
      "kc_mid": 1.15,
      "kc_end": 0.80,
      "root_depth_m": 0.60,
      "depletion_fraction_p": 0.40,
      "season_days": 120
    }
  },

  "mass_balance_test": {
    "_description": "Verify P + I + CR = ETc + DP + delta_S (inflow = outflow + storage)",
    "tolerance": 1e-10
  },

  "michigan_summer_scenario": {
    "_description": "Synthetic 90-day Michigan summer (June-August) for corn",
    "et0_mean_mm_day": 5.0,
    "et0_std_mm_day": 1.5,
    "precip_mean_mm_day": 2.5,
    "precip_prob": 0.30,
    "precip_depth_when_rain_mm": 8.0,
    "kc": 1.20,
    "soil": "sandy_loam",
    "expected_seasonal_et_range_mm": [300, 600],
    "expected_irrigation_triggers": "multiple"
  }
}
