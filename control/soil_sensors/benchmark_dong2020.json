{
  "_source": "Dong, Miller, Kelley (2020) Performance Evaluation of Soil Moisture Sensors in Coarse- and Fine-Textured Michigan Agricultural Soils. Agriculture 10(12), 598",
  "_doi": "10.3390/agriculture10120598",
  "_note": "Values digitized from published Tables 3 and 4, and Figures 2-10",

  "topp_equation": {
    "_description": "Topp et al. (1980) universal dielectric-to-VWC relationship",
    "_reference": "Topp, Davis, Annan (1980) Water Resources Research 16(3), 574-582",
    "coefficients": {
      "a": -5.3e-2,
      "b": 2.92e-2,
      "c": -5.5e-4,
      "d": 4.3e-6
    },
    "published_points": [
      {"epsilon": 3.0, "theta_expected": 0.030},
      {"epsilon": 5.0, "theta_expected": 0.080},
      {"epsilon": 10.0, "theta_expected": 0.188},
      {"epsilon": 15.0, "theta_expected": 0.276},
      {"epsilon": 20.0, "theta_expected": 0.345},
      {"epsilon": 25.0, "theta_expected": 0.400},
      {"epsilon": 30.0, "theta_expected": 0.444},
      {"epsilon": 40.0, "theta_expected": 0.510}
    ],
    "tolerance": 0.005
  },

  "statistical_formulas": {
    "_description": "Paper's Equations 1-3 for sensor evaluation",
    "rmse": "sqrt(1/N * sum((Mi - Pi)^2))",
    "ia": "1 - sum((Mi - Pi)^2) / sum((|Pi - M_bar| + |Mi - M_bar|)^2)",
    "mbe": "1/N * sum(Pi - Mi)",
    "criteria": {
      "mbe_threshold": 0.02,
      "rmse_threshold": 0.035,
      "ia_minimum": 0.8,
      "r2_minimum": 0.65
    }
  },

  "table_3_factory_calibration": {
    "_description": "Table 3: Statistical analysis comparing measured value to factory-calibrated sensor values",
    "cs616": {
      "sand":            {"mbe": -0.01, "rmse": 0.017, "ia": 0.96},
      "loamy_sand":      {"mbe": -0.03, "rmse": 0.039, "ia": 0.88},
      "sandy_clay_loam": {"mbe": -0.02, "rmse": 0.039, "ia": 0.84}
    },
    "ec5": {
      "sand":            {"mbe":  0.03, "rmse": 0.038, "ia": 0.90},
      "loamy_sand":      {"mbe": -0.03, "rmse": 0.035, "ia": 0.91},
      "sandy_clay_loam": {"mbe": -0.05, "rmse": 0.057, "ia": 0.75}
    }
  },

  "table_4_correction_equations": {
    "_description": "Table 4: Correction equations developed from laboratory data. theta_v = f(theta_vi) where theta_vi is factory-calibrated reading",
    "cs616": {
      "sand": {
        "linear":      {"form": "a*x + b", "r2": 0.98},
        "quadratic":   {"form": "a*x^2 + b*x + c", "r2": 0.99},
        "exponential": {"form": "a*exp(b*x)", "r2": 0.97},
        "logarithmic": {"form": "a*ln(x) + b", "r2": 0.96}
      },
      "loamy_sand": {
        "linear":      {"form": "a*x + b", "r2": 0.96},
        "quadratic":   {"form": "a*x^2 + b*x + c", "r2": 0.97}
      },
      "sandy_clay_loam": {
        "linear":      {"form": "a*x + b", "r2": 0.95},
        "quadratic":   {"form": "a*x^2 + b*x + c", "r2": 0.97},
        "exponential": {"form": "a*exp(b*x)", "r2": 0.94},
        "logarithmic": {"form": "a*ln(x) + b", "r2": 0.93}
      }
    },
    "ec5": {
      "sand": {
        "linear":      {"form": "a*x + b", "r2": 0.97},
        "exponential": {"form": "a*exp(b*x)", "r2": 0.96},
        "quadratic":   {"form": "a*x^2 + b*x + c", "r2": 0.98}
      },
      "loamy_sand": {
        "quadratic":   {"form": "a*x^2 + b*x + c", "r2": 0.96}
      },
      "sandy_clay_loam": {
        "quadratic":   {"form": "a*x^2 + b*x + c", "r2": 0.95}
      }
    }
  },

  "field_validation_rmse": {
    "_description": "RMSE improvements from field validation (Figures 5-10)",
    "cs616": {
      "sand":            {"factory": 0.017, "corrected": 0.006},
      "loamy_sand":      {"factory": 0.023, "corrected": 0.021},
      "sandy_clay_loam": {"factory": 0.039, "corrected": 0.012}
    },
    "ec5": {
      "sand":            {"factory": 0.018, "corrected": 0.004},
      "loamy_sand":      {"factory": 0.026, "corrected": 0.006},
      "sandy_clay_loam": {"factory": 0.047, "corrected": 0.020}
    }
  },

  "soil_classification": {
    "_description": "Table 1: Soil classification from MSU Soil Lab",
    "sand":            {"sand_pct": 96, "silt_pct": 2, "clay_pct": 2},
    "loamy_sand":      {"sand_pct": 82, "silt_pct": 10, "clay_pct": 8},
    "sandy_clay_loam": {"sand_pct": 52, "silt_pct": 20, "clay_pct": 28}
  }
}
