  "equation": {
    "scs_cn_runoff": "Q = (P - Ia)² / (P - Ia + S)  when P > Ia, else Q = 0",
    "initial_abstraction": "Ia = 0.2 × S  (standard, or Ia = 0.05 × S for updated)",
    "potential_retention": "S = (25400 / CN) - 254  [mm]  (or S = (1000/CN) - 10 [inches])",
    "units": {"Q": "mm", "P": "mm", "S": "mm", "CN": "dimensionless (0-100)"}
  },
  "cn_table": {
    "description": "Standard CN values for Hydrologic Soil Groups A-D, AMC II (average moisture)",
    "land_use": {
      "fallow_bare": {"A": 77, "B": 86, "C": 91, "D": 94},
      "row_crops_straight": {"A": 72, "B": 81, "C": 88, "D": 91},
      "row_crops_contoured": {"A": 67, "B": 78, "C": 85, "D": 89},
      "small_grain_straight": {"A": 65, "B": 76, "C": 84, "D": 88},
      "pasture_good": {"A": 39, "B": 61, "C": 74, "D": 80},
      "meadow": {"A": 30, "B": 58, "C": 71, "D": 78},
      "woods_good": {"A": 30, "B": 55, "C": 70, "D": 77},
      "farmstead": {"A": 59, "B": 74, "C": 82, "D": 86},
      "impervious": {"A": 98, "B": 98, "C": 98, "D": 98}
    }
  },
  "amc_adjustment": {
    "description": "Antecedent Moisture Condition adjustment (Chow 1964)",
    "amc_i_dry": "CN_I = CN_II / (2.281 - 0.01281 × CN_II)  [Hawkins 1985]",
    "amc_iii_wet": "CN_III = CN_II / (0.4036 + 0.0059 × CN_II)  [Hawkins 1985]",
    "test_cases": [
      {"cn_ii": 75, "expected_cn_i": 56.8, "expected_cn_iii": 88.6, "tolerance": 0.5},
      {"cn_ii": 85, "expected_cn_i": 71.3, "expected_cn_iii": 93.9, "tolerance": 0.5},
      {"cn_ii": 60, "expected_cn_i": 39.7, "expected_cn_iii": 79.2, "tolerance": 0.5}
    ]
  },
