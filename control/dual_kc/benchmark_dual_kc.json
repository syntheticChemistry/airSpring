  "equations": {
    "eq_69": {
      "_description": "ETc = (Kcb \u00d7 Ks + Ke) \u00d7 ET0 \u2014 dual crop coefficient",
      "test_cases": [
        {
          "label": "full_cover_no_stress",
          "kcb": 1.15,
          "ks": 1.0,
          "ke": 0.0,
          "et0": 5.0,
          "expected_etc": 5.75,
          "tolerance": 1e-06
        },
        {
          "label": "mid_season_with_evap",
          "kcb": 1.1,
          "ks": 1.0,
          "ke": 0.1,
          "et0": 4.5,
          "expected_etc": 5.4,
          "tolerance": 1e-06
        },
        {
          "label": "stressed_with_evap",
          "kcb": 1.15,
          "ks": 0.6,
          "ke": 0.15,
          "et0": 6.0,
          "expected_etc": 5.04,
          "tolerance": 1e-06
        },
        {
          "label": "initial_bare_soil",
          "kcb": 0.15,
          "ks": 1.0,
          "ke": 0.85,
          "et0": 3.0,
          "expected_etc": 3.0,
          "tolerance": 1e-06
        }
      ],
      "tolerance": 1e-06
    },
    "eq_71_kc_max": {
      "_description": "Kc_max = max(1.2 + [0.04(u2-2) - 0.004(RHmin-45)](h/3)^0.3, Kcb + 0.05)",
      "_reference": "FAO-56 Eq. 72 (labeled 71 in some editions)",
      "test_cases": [
        {
          "label": "standard_climate_tall_crop",
          "u2": 2.0,
          "rh_min": 45.0,
          "h": 2.0,
          "kcb": 1.15,
          "expected_kc_max": 1.2,
          "tolerance": 1e-06
        },
        {
          "label": "windy_dry_tall_crop",
          "u2": 4.0,
          "rh_min": 25.0,
          "h": 2.0,
          "kcb": 1.15,
          "expected_kc_max": 1.3417,
          "tolerance": 1e-06
        },
        {
          "label": "calm_humid_short_crop",
          "u2": 1.0,
          "rh_min": 70.0,
          "h": 0.4,
          "kcb": 1.1,
          "expected_kc_max": 1.15,
          "tolerance": 1e-06
        },
        {
          "label": "turfgrass_standard",
          "u2": 2.0,
          "rh_min": 45.0,
          "h": 0.1,
          "kcb": 0.85,
          "expected_kc_max": 1.2,
          "tolerance": 1e-06
        }
      ],
      "tolerance": 1e-06
    },
    "eq_73_tew": {
      "_description": "TEW = 1000 \u00d7 (\u03b8FC - 0.5\u00d7\u03b8WP) \u00d7 Ze \u2014 total evaporable water",
      "_units": "mm",
      "test_cases": [
        {
          "label": "sandy_loam_ze10",
          "theta_fc": 0.23,
          "theta_wp": 0.1,
          "ze_m": 0.1,
          "expected_tew": 18.0,
          "tolerance": 1e-06
        },
        {
          "label": "loam_ze10",
          "theta_fc": 0.3,
          "theta_wp": 0.15,
          "ze_m": 0.1,
          "expected_tew": 22.5,
          "tolerance": 1e-06
        },
        {
          "label": "clay_ze10",
          "theta_fc": 0.42,
          "theta_wp": 0.25,
          "ze_m": 0.1,
          "expected_tew": 29.5,
          "tolerance": 1e-06
        },
        {
          "label": "sandy_loam_ze15",
          "theta_fc": 0.23,
          "theta_wp": 0.1,
          "ze_m": 0.15,
          "expected_tew": 27.0,
          "tolerance": 1e-06
        }
      ],
      "tolerance": 1e-06
    },
    "eq_72_kr": {
      "_description": "Kr = (TEW - De) / (TEW - REW) for De > REW, Kr = 1 for De \u2264 REW",
      "test_cases": [
        {
          "label": "fully_wet",
          "tew": 22.5,
          "rew": 9.0,
          "de": 0.0,
          "expected_kr": 1.0,
          "tolerance": 1e-06
        },
        {
          "label": "at_rew_boundary",
          "tew": 22.5,
          "rew": 9.0,
          "de": 9.0,
          "expected_kr": 1.0,
          "tolerance": 1e-06
        },
        {
          "label": "mid_stage2",
          "tew": 22.5,
          "rew": 9.0,
          "de": 15.75,
          "expected_kr": 0.5,
          "tolerance": 1e-06
        },
        {
          "label": "near_dry",
          "tew": 22.5,
          "rew": 9.0,
          "de": 21.15,
          "expected_kr": 0.1,
          "tolerance": 1e-06
        },
        {
          "label": "fully_dry",
          "tew": 22.5,
          "rew": 9.0,
          "de": 22.5,
          "expected_kr": 0.0,
          "tolerance": 1e-06
        }
      ],
      "tolerance": 1e-06
    }
  },
