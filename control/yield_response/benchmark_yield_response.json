          "stages_eta_etc": [1.0, 0.7, 1.0, 1.0],
          "expected_ratio": 0.550,
          "tolerance": 0.001,
          "note": "Only flowering stage is stressed: 1*1*(1-1.5*0.3)*1*1 = 0.55"
